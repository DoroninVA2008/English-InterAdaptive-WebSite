# Зависимости — самая тяжёлая папка, её никогда не пушат
node_modules/

# Результат сборки — генерируется автоматически
dist/

# Кэш и временные файлы
.cache/
*.log
npm-debug.log*

# Файлы IDE (если пользуешься VS Code, WebStorm и т.д.)
.vscode/
.idea/

# Файлы операционной системы
.DS_Store
Thumbs.db